{
  "name": "codex-discord-rich-presence",
  "version": "0.1.0",
  "description": "Discord Rich Presence for Codex using Codex hooks.",
  "type": "module",
  "bin": {
    "codex-discord": "./dist/cli.js"
  },
  "files": [
